{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/_app/*", "/*.{ico,png,jpg,svg,webp,js,css,woff2}"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".webmanifest": "application/manifest+json"
  }
}
